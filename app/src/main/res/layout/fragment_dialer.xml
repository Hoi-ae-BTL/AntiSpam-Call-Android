<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical">

    <!-- Top section: Search results (Smart Dialing) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_dialer_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Current input section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_card"
        android:elevation="0dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <TextView
            android:id="@+id/tv_dialed_number"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:hint="Sẵn sàng gọi"
            android:textColor="@color/colorPrimary"
            android:textSize="36sp"
            android:fontFamily="sans-serif-medium" />

        <ImageButton
            android:id="@+id/btn_backspace"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_input_delete"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <!-- Numpad section -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_card"
        android:columnCount="3"
        android:paddingBottom="16dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:rowCount="4">

        <!-- Row 1 -->
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_1" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="1\n " android:textSize="28sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_2" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="2\nABC" android:textSize="26sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_3" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="3\nDEF" android:textSize="26sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>

        <!-- Row 2 -->
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_4" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="4\nGHI" android:textSize="26sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_5" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="5\nJKL" android:textSize="26sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_6" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="6\nMNO" android:textSize="26sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>

        <!-- Row 3 -->
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_7" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="7\nPQRS" android:textSize="24sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_8" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="8\nTUV" android:textSize="26sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_9" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="9\nWXYZ" android:textSize="24sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>

        <!-- Row 4 -->
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1"><Button android:id="@+id/btn_star" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="*\n " android:textSize="28sp" android:textColor="@color/text_secondary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1"><Button android:id="@+id/btn_0" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="0\n+" android:textSize="26sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1"><Button android:id="@+id/btn_hash" android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="#\n " android:textSize="28sp" android:textColor="@color/text_secondary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
    </GridLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_card"
        android:paddingBottom="24dp"
        android:paddingTop="8dp">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_call"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:backgroundTint="@color/status_safe"
            android:src="@android:drawable/ic_menu_call"
            app:borderWidth="0dp"
            app:fabSize="normal"
            app:tint="@android:color/white" 
            app:elevation="8dp"/>
    </FrameLayout>
</LinearLayout>
