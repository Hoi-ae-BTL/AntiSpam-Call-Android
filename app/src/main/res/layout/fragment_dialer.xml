<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical">

    <!-- Top section: Search results (Smart Dialing) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_dialer_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="24dp"
            android:background="@color/surface_card">

            <!-- Current input section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp">

                <TextView
                    android:id="@+id/tv_dialed_number"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:hint="Sẵn sàng gọi"
                    android:textColor="@color/colorPrimary"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-medium" />

                <ImageButton
                    android:id="@+id/btn_backspace"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_input_delete"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="16dp"
                android:background="#F0F0F0" />

            <!-- Numpad section -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:paddingHorizontal="16dp"
                android:rowCount="4">

                <!-- Row 1 -->
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_1" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="1\n " android:textSize="24sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_2" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="2\nABC" android:textSize="22sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_3" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="3\nDEF" android:textSize="22sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>

                <!-- Row 2 -->
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_4" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="4\nGHI" android:textSize="22sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_5" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="5\nJKL" android:textSize="22sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_6" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="6\nMNO" android:textSize="22sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>

                <!-- Row 3 -->
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_7" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="7\nPQRS" android:textSize="20sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_8" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="8\nTUV" android:textSize="22sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_9" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="9\nWXYZ" android:textSize="20sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>

                <!-- Row 4 -->
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_star" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="*\n " android:textSize="24sp" android:textColor="@color/text_secondary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_0" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="0\n+" android:textSize="22sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginBottom="8dp"><Button android:id="@+id/btn_hash" android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="center" android:background="@drawable/bg_numpad_key" android:text="#\n " android:textSize="24sp" android:textColor="@color/text_secondary" android:fontFamily="sans-serif-light" style="?android:attr/borderlessButtonStyle"/></FrameLayout>
            </GridLayout>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_call"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/colorPrimary"
                android:src="@android:drawable/ic_menu_call"
                app:borderWidth="0dp"
                app:fabSize="normal"
                app:tint="@android:color/white" 
                app:elevation="4dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
